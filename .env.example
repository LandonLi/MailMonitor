# IMAP 服务器配置
IMAP_SERVER=imap.exmail.qq.com
IMAP_PORT=993
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_app_password
MAIL_FOLDER=INBOX

# Pushover 推送配置 (必填，否则只能监控不能推送)
PUSHOVER_APP_TOKEN=your_pushover_app_token
PUSHOVER_USER_KEY=your_pushover_user_key

# 网络代理 (可选)
# 支持 HTTP 或 SOCKS 代理，例如: http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
PROXY_URL=

# 心跳间隔 (单位：分钟，可选，默认 15)
# 若频繁出现 "connection has been closed (EOF)"，可将其调小（如 9）
HEARTBEAT_INTERVAL=15